{
  "manifest_version": 3,
  "name": "Twitch VOD & Clip Downloader",
  "version": "1.1.0",
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "permissions": ["downloads", "storage"],
  "host_permissions": [
    "https://*.twitch.tv/*",
    "https://*.ttvnw.net/*",
    "https://*.cloudfront.net/*",
    "https://*.twitchcdn.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*", "https://clips.twitch.tv/*"],
      "js": ["shared.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Twitch VOD & Clip Downloader"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
